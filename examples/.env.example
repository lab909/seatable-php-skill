# SeaTable Connection
# Create an API Token in the SeaTable UI: Base → ··· menu → API Token → Add Token
SEATABLE_API_TOKEN=your_api_token_here

# Your SeaTable server URL (no trailing slash)
# For cloud: https://cloud.seatable.io
# For self-hosted: https://your-seatable-server.com
SEATABLE_SERVER_URL=https://cloud.seatable.io
