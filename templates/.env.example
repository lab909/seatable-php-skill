# ============================================================
# SeaTable — Base Credentials
# Required for every project. Get these from the SeaTable UI.
# ============================================================

# Your SeaTable server URL (no trailing slash)
# Self-hosted: https://your-seatable-server.com
# Cloud:       https://cloud.seatable.io
SEATABLE_HOST=https://your-seatable-server.com

# 40-char API token created in SeaTable UI → Base → API Tokens
SEATABLE_API_TOKEN=your_40_char_api_token_here

# UUID of the target base (visible in the base URL or API token settings)
SEATABLE_BASE_UUID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ============================================================
# SeaTable — Schema IDs
# Run `php discover-ids.php` to generate these values.
# Each "Link to other records" column needs a LINK_ID_* entry.
# ============================================================

# Example — replace with your actual table and link IDs:
# TABLE_ID_AUDIOBOOKS=Ab12
# TABLE_ID_CATEGORIES=Cd34
# LINK_ID_CATEGORIES=Ef56
